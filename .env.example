# ============================================================================
#  LSC i5.0 — Variables de entorno
#  Copia este archivo a `.env` y ajusta los valores antes de desplegar.
# ============================================================================

# ---- General ----
APP_NAME=LSC i5.0
APP_ENV=development            # development | production
DEBUG=true
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Modo desarrollador: expone las pantallas/endpoints de dataset y entrenamiento
DEV_MODE=true

# ---- Producción (Caddy + HTTPS) ----
# Dominio con DNS (registro A) apuntando a la IP pública del servidor.
# Lo usa docker-compose.prod.yml / Caddyfile para emitir el certificado TLS.
DOMAIN=lsc.midominio.com
# En producción: APP_ENV=production, DEBUG=false, DEV_MODE=false,
# ALLOWED_ORIGINS=https://lsc.midominio.com  (el override prod ya los fuerza).

# ---- Puertos ----
BACKEND_PORT=8000
FRONTEND_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
OLLAMA_PORT=11434

# ---- PostgreSQL ----
POSTGRES_USER=lsc
POSTGRES_PASSWORD=lsc_secret
POSTGRES_DB=lsc_db
POSTGRES_HOST=db
DATABASE_URL=postgresql+asyncpg://lsc:lsc_secret@db:5432/lsc_db

# ---- Redis (Context Agent / KV Cache) ----
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0

# ---- Ollama / Llama 3.1 ----
OLLAMA_ENABLED=true            # false donde no haya Ollama (usa fallback gramatical)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1          # llama3.1 (8B) | llama3 | llama3.2:3b | llama3.1:70b
OLLAMA_TIMEOUT=60

# ---- Memoria contextual (KV Cache) ----
CONTEXT_TTL_SECONDS=900        # persistencia temporal del contexto por sesión
HISTORY_WINDOW=5              # nº de frases previas conservadas
MAX_CONTEXT_GLOSSES=12       # nº máx. de glosas activas en una frase

# ---- Modelo ML ----
MODEL_PATH=/app/ml_store/lsc_transformer.pt
LABELS_PATH=/app/ml_store/labels.json
SEQUENCE_LENGTH=30
CONFIDENCE_THRESHOLD=0.65

# ---- Dataset / entrenamiento ----
DATA_DIR=data
MODEL_STORE=ml_store
